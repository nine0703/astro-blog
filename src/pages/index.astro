---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { getPath } from "@/utils/getPath";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const previewPosts = [...featuredPosts, ...recentPosts].slice(
  0,
  SITE.postPerIndex
);

const entryRoutes = [
  {
    icon: "⚡",
    title: "快速测试",
    desc: "用几分钟完成一次配置评估，给新用户一个明确的 Agent 起步方案。",
    meta: "新手入口",
  },
  {
    icon: "🎮",
    title: "直接体验",
    desc: "把学习过程游戏化，用养成反馈推动用户持续阅读、答题和升级。",
    meta: "即时反馈",
  },
  {
    icon: "📚",
    title: "系统学习",
    desc: "用完整方法论承接深度用户，把零散技巧组织成可执行的操作手册。",
    meta: "体系内容",
  },
];

const moduleCards = [
  {
    title: "养虾36计",
    desc: "将 AI Agent 的训练、协作、迭代拆成 36 个实战方法，每一篇都围绕问题、场景、步骤和提示词展开。",
    meta: "方法论攻略",
  },
  {
    title: "ShrimpFi",
    desc: "把方法论变成养成体验：读内容、答题、解锁技能，让角色成长成为知识掌握程度的可视化反馈。",
    meta: "游戏化学习",
  },
  {
    title: "虾24章经",
    desc: "作为长期认知框架，补充原则、判断和复盘方法，帮助用户知道该做什么，也知道为什么做。",
    meta: "认知心法",
  },
  {
    title: "思享录",
    desc: "保留随笔、经验和阶段性思考，让平台既有教程，也有持续更新的真实记录。",
    meta: "观点内容",
  },
];

const playSteps = [
  {
    title: "读攻略",
    desc: "先从方法论文章进入，理解一个真实场景里的问题和解决动作。",
  },
  {
    title: "答题解锁",
    desc: "用问答校验是否真的理解内容，再把对应技能加入成长路径。",
  },
  {
    title: "养成进化",
    desc: "通过喂养、训练和技能学习，让 Agent 从初始状态持续升级。",
  },
  {
    title: "沉淀成果",
    desc: "把掌握过的知识、能力和阶段成果沉淀为可展示的个人资产。",
  },
];

const faqs = [
  {
    question: "SingClaw 的核心是什么？",
    answer:
      "它把 AI Agent 训练方法、内容学习和养成游戏放在同一个叙事里，让用户不只是读文章，而是持续把知识喂给自己的助手。",
  },
  {
    question: "36计和游戏有什么关系？",
    answer:
      "36计负责提供可执行的方法论，游戏负责把学习反馈可视化。读完、答对、解锁，最终让角色强度对应知识掌握程度。",
  },
  {
    question: "为什么强调“养”？",
    answer:
      "AI 助手不是一次安装就完成的工具，它需要数据、流程、环境和持续迭代。养成叙事能帮助用户理解长期运营的重要性。",
  },
];
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index">
    <section class="bg-base-100">
      <div
        class="mx-auto w-full max-w-5xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8 lg:py-24"
      >
        <div
          class="space-y-8 lg:grid lg:grid-cols-[minmax(0,1.2fr)_minmax(18rem,24rem)] lg:gap-10 lg:space-y-0"
        >
          <div class="space-y-6">
            <p class="badge badge-outline">SingClaw content probe</p>

            <div class="space-y-4">
              <h1
                id="theme-probe-title"
                class="max-w-3xl text-4xl font-bold tracking-tight sm:text-5xl"
              >
                把 AI 助手养成真正能干活的超级员工
              </h1>
              <p class="max-w-2xl text-base text-base-content/70 sm:text-lg">
                这次只抽取 SingClaw
                的内容方向：用方法论、测试入口和游戏化成长，把 AI Agent
                从“装好工具”推进到“持续训练、持续进化、持续复盘”。
              </p>
            </div>

            <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
              <a href="/posts/" class="btn w-full btn-primary sm:w-auto">
                阅读方法论
                <IconArrowRight class="inline-block rtl:-rotate-180" />
              </a>
              <a href="/about/" class="btn w-full btn-outline sm:w-auto">
                了解项目
              </a>
            </div>

            <ul class="grid gap-3 sm:grid-cols-2">
              <li
                class="rounded-box border border-base-300 bg-base-100 px-4 py-3 text-sm text-base-content/75 shadow-sm"
              >
                36 篇方法论内容入口
              </li>
              <li
                class="rounded-box border border-base-300 bg-base-100 px-4 py-3 text-sm text-base-content/75 shadow-sm"
              >
                3 分钟配置测试路径
              </li>
              <li
                class="rounded-box border border-base-300 bg-base-100 px-4 py-3 text-sm text-base-content/75 shadow-sm"
              >
                游戏化学习反馈机制
              </li>
              <li
                class="rounded-box border border-base-300 bg-base-100 px-4 py-3 text-sm text-base-content/75 shadow-sm"
              >
                知识资产沉淀叙事
              </li>
            </ul>
          </div>

          <aside class="card border border-base-300 bg-base-100 shadow-sm">
            <div class="card-body gap-4">
              <p
                class="text-sm font-semibold tracking-wide text-base-content/60 uppercase"
              >
                Core idea
              </p>
              <div class="rounded-box border border-base-300 bg-base-200">
                <div
                  class="flex items-center gap-2 border-b border-base-300 px-4 py-3 text-xs tracking-wide text-base-content/60 uppercase"
                >
                  <span class="h-2.5 w-2.5 rounded-full bg-success"></span>
                  <span>Agent growth loop</span>
                </div>
                <div class="px-4 py-4 text-sm leading-6 text-base-content/70">
                  内容不再只是文章列表，而是“读内容 → 做测试 → 解锁能力 →
                  形成可展示成果”的连续路径。
                </div>
              </div>
              <div class="divider my-0"></div>
              <p class="text-sm text-base-content/70">
                页面结构仍使用当前企业门户样式，内容层借鉴 SingClaw 的产品叙事。
              </p>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section
      class="mx-auto w-full max-w-6xl px-4 py-16 sm:px-6 md:py-24 lg:px-8"
      aria-labelledby="route-title"
    >
      <div class="mb-8 max-w-3xl">
        <h2
          id="route-title"
          class="text-2xl font-bold tracking-tight md:text-3xl"
        >
          3 条开始路径
        </h2>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {
          entryRoutes.map(card => (
            <article class="card border border-base-300 bg-base-100 shadow-sm">
              <div class="card-body gap-4">
                <span class="badge badge-outline badge-primary">
                  {card.icon}
                </span>
                <h3 class="card-title">{card.title}</h3>
                <p class="text-sm leading-6 text-base-content/70">
                  {card.desc}
                </p>
                <small class="text-xs font-semibold text-base-content/50">
                  {card.meta}
                </small>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="bg-base-200 py-16" aria-labelledby="modules-title">
      <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="mb-8 max-w-3xl">
          <h2
            id="modules-title"
            class="text-2xl font-bold tracking-tight md:text-3xl"
          >
            核心内容模块
          </h2>
          <p class="mt-3 text-base text-base-content/70">
            方法论是骨架，游戏化体验是反馈，长期认知内容负责把用户留在体系里。
          </p>
        </div>

        <ul class="grid grid-cols-1 gap-5 md:grid-cols-2">
          {
            moduleCards.map(card => (
              <li class="card border border-base-300 bg-base-100 shadow-sm">
                <div class="card-body">
                  <span class="badge w-fit badge-ghost">{card.meta}</span>
                  <h3 class="card-title">{card.title}</h3>
                  <p class="text-sm leading-6 text-base-content/70">
                    {card.desc}
                  </p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section
      class="mx-auto w-full max-w-6xl px-4 py-16 sm:px-6 md:py-24 lg:px-8"
      aria-labelledby="steps-title"
    >
      <div class="mb-8 max-w-3xl">
        <h2
          id="steps-title"
          class="text-2xl font-bold tracking-tight md:text-3xl"
        >
          从内容到成长的 4 步
        </h2>
      </div>

      <ol class="grid grid-cols-1 gap-5 md:grid-cols-4">
        {
          playSteps.map((step, index) => (
            <li class="card border border-base-300 bg-base-100 shadow-sm">
              <div class="card-body">
                <span class="badge w-fit badge-primary">{index + 1}</span>
                <h3 class="card-title text-base">{step.title}</h3>
                <p class="text-sm leading-6 text-base-content/70">
                  {step.desc}
                </p>
              </div>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="bg-base-200 py-16" aria-labelledby="faq-title">
      <div class="mx-auto w-full max-w-3xl px-4 sm:px-6 lg:px-8">
        <div class="mb-8 max-w-3xl">
          <h2
            id="faq-title"
            class="text-2xl font-bold tracking-tight md:text-3xl"
          >
            FAQ
          </h2>
        </div>

        <div class="space-y-3">
          {
            faqs.map((faq, index) => (
              <div class="collapse-arrow collapse border border-base-300 bg-base-100">
                <input type="radio" name="homepage-faq" checked={index === 0} />
                <h3 class="collapse-title font-semibold">{faq.question}</h3>
                <div class="collapse-content text-sm leading-6 text-base-content/70">
                  {faq.answer}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section
      class="mx-auto w-full max-w-6xl px-4 py-16 sm:px-6 md:py-24 lg:px-8"
      aria-labelledby="posts-title"
    >
      <div>
        <div class="mb-8 max-w-3xl">
          <h2
            id="posts-title"
            class="text-2xl font-bold tracking-tight md:text-3xl"
          >
            最近内容
          </h2>
        </div>

        <ul class="grid grid-cols-1 gap-5 md:grid-cols-2">
          {
            previewPosts.map(({ id, data, filePath }) => (
              <li class="card border border-base-300 bg-base-100 shadow-sm">
                <div class="card-body">
                  <a
                    href={getPath(id, filePath)}
                    class="card-title hover:text-primary"
                  >
                    <h3>{data.title}</h3>
                  </a>
                  <p class="text-sm leading-6 text-base-content/70">
                    {data.description}
                  </p>
                </div>
              </li>
            ))
          }
        </ul>

        <a href="/posts/" class="btn mt-8 px-0 btn-link">
          查看全部洞察
          <IconArrowRight class="inline-block rtl:-rotate-180" />
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
