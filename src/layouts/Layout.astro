---
import '@/styles/global.css'

import { ClientRouter } from 'astro:transitions'

import HeadSeo from '@/layouts/HeadSeo.astro'
import Header from '@/components/layout/header'
import Footer from '@/components/layout/footer'

import type { NavigationSection } from '@/components/blocks/menu-navigation'

const navigationData: NavigationSection[] = [
  {
    title: '首页',
    href: '/#home'
  },
  {
    title: '解决方案',
    href: '/#categories'
  },
  {
    title: '行业洞察',
    href: '/#categories'
  },
  {
    title: '联系我们',
    href: '/contact-us'
  }
]

interface Props {
  title?: string
  description?: string
  image?: string
  type?: 'website' | 'article'
  keywords?: string
  author?: string
  publishedTime?: string
  modifiedTime?: string
  noindex?: boolean
  nofollow?: boolean
  schema?: Record<string, any>
}

const seoProps = Astro.props as Props
---

<!doctype html>
<html lang='zh-CN' class='scroll-smooth'>
  <head>
    <HeadSeo {...seoProps} />
    <ClientRouter />
    <script is:inline>
      ;(function () {
        const getTheme = () => {
          if (typeof localStorage !== 'undefined') {
            const stored = localStorage.getItem('theme')
            if (stored === 'light' || stored === 'dark') {
              return stored
            }
          }
          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'
        }

        const applyTheme = () => {
          const theme = getTheme()
          if (theme === 'dark') {
            document.documentElement.classList.add('dark')
          } else {
            document.documentElement.classList.remove('dark')
          }
        }

        // Apply theme immediately on initial load
        applyTheme()

        // Re-apply theme on Astro page transitions
        document.addEventListener('astro:page-load', applyTheme)
      })()
    </script>
    <script is:inline>
      ;(() => {
        const widgetScriptId = 'ai-consulting-widget-script'
        const widgetKey = 'pub_4272141953604bd488957f31f6985544'
        const widgetSrc = 'http://localhost:5173/embed.js'
        const widgetSelector = `[data-ai-consulting-widget="${widgetKey}"]`

        const mountWidget = () => {
          if (document.querySelector(widgetSelector)) return
          if (!document.body) {
            document.addEventListener('DOMContentLoaded', mountWidget, { once: true })
            return
          }

          document.getElementById(widgetScriptId)?.remove()

          const script = document.createElement('script')
          script.id = widgetScriptId
          script.src = widgetSrc
          script.async = true
          script.setAttribute('data-public-embed-key', widgetKey)
          document.body.appendChild(script)
        }

        if (!(window as any).__enterprisePortalAiWidgetMounted) {
          ;(window as any).__enterprisePortalAiWidgetMounted = true

          document.addEventListener('astro:before-swap', event => {
            const nextDocument = (event as any).newDocument as Document
            const widget = document.querySelector(widgetSelector)
            const style = document.getElementById('ai-consulting-widget-nudge-style')

            if (style) {
              nextDocument.head.appendChild(style)
            }

            if (widget) {
              nextDocument.body.appendChild(widget)
            }
          })

          document.addEventListener('astro:page-load', mountWidget)
        }

        mountWidget()
      })()
    </script>
    <style>
      /* Disable all view transitions while keeping client-side navigation */
      ::view-transition-group(*),
      ::view-transition-old(*),
      ::view-transition-new(*) {
        animation-duration: 0ms !important;
      }
    </style>
  </head>
  <body class='flex min-h-full w-full flex-auto flex-col'>
    <div class='flex flex-col'>
      {/* Header Section */}
      <Header navigationData={navigationData} client:load />

      <main class='flex flex-col *:scroll-mt-15.5'><slot /></main>

      {/* Footer Section */}
      <Footer client:load />
    </div>
  </body>
</html>
